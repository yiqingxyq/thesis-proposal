\@writefile{lof}{\contentsline {figure}{\numberline {5.4}{\ignorespaces Controlled experiments on training data characteristics. (a)\nobreakspace  {}\textbf  {Output Format:} Removing the file editing actions (\texttt  {str\_replace}) from function localization trajectories causes a large drop in SWE-bench resolution rate. (b)\nobreakspace  {}\textbf  {Repo-Exploration:} script-level code generation (LCB) does not effectively transfer to repo-level issue-solving and even underperforms documentation generation, a simple repo-level task. (c)\nobreakspace  {}\textbf  {Task Complexity:} Transfer improves as training tasks become more complex. (d)\nobreakspace  {}\textbf  {Trajectory Complexity:} With a fixed data size, training on longer (more agent steps) trajectories substantially improves downstream performance.\relax }}{57}{figure.caption.41}\protected@file@percent }
\newlabel{fig:ablation}{{5.4}{57}{Controlled experiments on training data characteristics. (a)~\textbf {Output Format:} Removing the file editing actions (\texttt {str\_replace}) from function localization trajectories causes a large drop in SWE-bench resolution rate. (b)~\textbf {Repo-Exploration:} script-level code generation (LCB) does not effectively transfer to repo-level issue-solving and even underperforms documentation generation, a simple repo-level task. (c)~\textbf {Task Complexity:} Transfer improves as training tasks become more complex. (d)~\textbf {Trajectory Complexity:} With a fixed data size, training on longer (more agent steps) trajectories substantially improves downstream performance.\relax }{figure.caption.41}{}}
\newlabel{fig:ablation@cref}{{[figure][4][5]5.4}{[1][56][]57}}
